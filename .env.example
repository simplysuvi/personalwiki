# Copy this file to .env at the repo root, then adjust as needed.
# Relative paths are resolved from the repository root.

KB_USER_NAME=User
KB_ASSISTANT_NAME=Assistant

LLM_BACKEND=llamacpp
REASONING_MODEL_PATH=models/gemma-4-12b-it-Q4_K_M.gguf
EMBEDDING_MODEL_PATH=models/nomic-embed-text-v1.5.Q4_K_M.gguf
CHAT_TEMPLATE_PATH=templates/gemma4-tools.jinja

N_GPU_LAYERS=-1
N_CTX=16384
N_THREADS=8
CONTEXT_RESERVE=1536
MAX_AGENT_ITERATIONS=10
MAX_FILE_SIZE_CHARS=8000
BM25_TOP_K=8

PDF_CONVERTER=hybrid
SCANNED_TEXT_THRESHOLD=40

# Used by setup.sh when downloading the default models.
REASONING_MODEL_REPO=unsloth/gemma-4-12b-it-GGUF
REASONING_MODEL_FILE=gemma-4-12b-it-Q4_K_M.gguf
EMBEDDING_MODEL_REPO=nomic-ai/nomic-embed-text-v1.5-GGUF
EMBEDDING_MODEL_FILE=nomic-embed-text-v1.5.Q4_K_M.gguf
